{
  "$schema": "https://claude.ai/schemas/marketplace.json",
  "name": "infodom-llm",
  "description": "Internal LLM skills for the Infodom / Locumo engineering team",
  "version": "1.0.1",
  "owner": {
    "name": "Infodom Team",
    "email": "pawel.kankowski@gmail.com"
  },
  "metadata": {
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "pr-description",
      "source": "./plugins/pr-description",
      "description": "Create, improve, and update GitHub Pull Request descriptions for the current branch or a specified PR number",
      "version": "1.0.1",
      "author": {
        "name": "Infodom Team"
      },
      "repository": "https://github.com/infodomy/infodom-llm-marketplace",
      "license": "MIT",
      "category": "developer-tools",
      "tags": [
        "git",
        "github",
        "pull-request",
        "workflow"
      ]
    },
    {
      "name": "save-to-docs",
      "source": "./plugins/save-to-docs",
      "description": "Save information to the infodom-docs repository and open a GitHub PR with the changes",
      "version": "1.0.1",
      "author": {
        "name": "Infodom Team"
      },
      "repository": "https://github.com/infodomy/infodom-llm-marketplace",
      "license": "MIT",
      "category": "documentation",
      "tags": [
        "docs",
        "github",
        "pull-request",
        "knowledge-base"
      ]
    },
    {
      "name": "infodom-db",
      "source": "./plugins/infodom-db",
      "description": "PostgreSQL/PostGIS database assistant for the Infodom production database \u2014 schema-aware SQL queries and data exploration",
      "version": "1.0.1",
      "author": {
        "name": "Infodom Team"
      },
      "repository": "https://github.com/infodomy/infodom-llm-marketplace",
      "license": "MIT",
      "category": "database",
      "tags": [
        "postgresql",
        "postgis",
        "sql",
        "infodom",
        "database"
      ]
    },
    {
      "name": "fix-grafana-dashboard",
      "source": "./plugins/fix-grafana-dashboard",
      "description": "Modify Grafana dashboards via Playwright MCP and the Grafana REST API \u2014 create, update, and reload provisioned dashboards",
      "version": "1.0.1",
      "author": {
        "name": "Infodom Team"
      },
      "repository": "https://github.com/infodomy/infodom-llm-marketplace",
      "license": "MIT",
      "category": "observability",
      "tags": [
        "grafana",
        "prometheus",
        "monitoring",
        "sre",
        "dashboards"
      ]
    }
  ]
}
